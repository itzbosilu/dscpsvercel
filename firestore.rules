rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all safety filter
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Matches our state documents containing rosters, configurations, gallery assets and workload matrices
    match /app_state/{stateKey} {
      allow read, write: if isSignedIn() && isValidId(stateKey);
    }
  }
}
